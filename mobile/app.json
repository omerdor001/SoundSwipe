{
  "expo": {
    "name": "SoundSwipe",
    "slug": "soundswipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "soundswipe",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soundswipe.app"
    },
    "android": {
      "package": "com.soundswipe.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "soundswipe"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "sdkVersion": "52.0.0"
  }
}
