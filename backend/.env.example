# ─────────────────────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/soundswipe"

# JWT secret — any long random string
JWT_SECRET="change-this-to-a-long-random-secret-string"

# Express port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# ── Spotify API ───────────────────────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard
# 2. Click "Create app"
# 3. Set Redirect URI to http://localhost:3001 (required even for Client Credentials)
# 4. Copy Client ID and Client Secret below
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"
